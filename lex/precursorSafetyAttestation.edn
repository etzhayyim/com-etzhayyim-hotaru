{:lexicon 1
 :id "com.etzhayyim.hotaru.precursorSafetyAttestation"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["designId" "inSourcing" "cleared" "precursorCount"]
    :properties
    {:designId       {:type "string" :description "→ crystalGrowthDesign.crystalId / waferSpec.waferId"}
     :inSourcing     {:type "string" :enum ["recycled" "conflict-free-attested"]
                      :description "G4 — conflict-mineral In/Ga clean-sourcing attestation"}
     :precursorCount {:type "integer"}
     :exportControls {:type "array" :items {:type "string" :enum ["none" "ear" "itar"]}
                      :description "ITAR/EAR posture per ADR-2605265500 §2 jurisdictional-risk attestation"}
     :acuteToxicAcknowledged {:type "boolean" :const true
                              :description "G3 — every acute-toxic precursor (PH3) acknowledged; record only exists after the refusal gate clears"}
     :cleared        {:type "boolean" :const true
                      :description "G3/G4 — a refusal gate; an attestation exists only when review CLEARED (refused designs produce no attestation)"}
     :sourcing       {:type "string" :enum ["representative" "verified"]}}}}}}
