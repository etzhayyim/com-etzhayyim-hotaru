{:lexicon 1
 :id "com.etzhayyim.hotaru.commonsReadinessReport"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["substrateCommonsReady" "r4GateSatisfiable" "stagesCovered" "stagesTotal"]
    :properties
    {:stagesCovered         {:type "integer" :description "substrate stages with ≥1 open-mature process"}
     :stagesTotal           {:type "integer" :const 4 :description "synthesis / bulk-growth / wafering / surface-prep"}
     :substrateCommonsReady {:type "boolean" :description "all substrate stages open-mature"}
     :epitaxyOpenMature     {:type "boolean" :description "the vendor-IP-dense gap leg (ADR-2605265500 §2)"}
     :r4GateSatisfiable     {:type "boolean"
                             :description "G3 NON-ADJUDICATING — whether the open commons alone satisfies the ADR-2605265500 §2 R4+ gate. hotaru REPORTS this; Council DECIDES the gate. False ⇒ fabrication stays PROHIBITED through R3."}
     :maturityScore         {:type "integer"
                             :description "commons-maturity score ×100 (minor-units; open-mature=100/open-emerging=50/gap=0 averaged over the 4 substrate stages)"}
     :fabricationProhibited {:type "boolean" :const true
                             :description "G3 — this report NEVER opens fabrication; the prohibition stands (ADR-2605265500 §2)"}
     :conflictFlagged       {:type "integer" :description "crystal designs with non-clean In/Ga sourcing"}
     :sourcing              {:type "string" :enum ["derived"]
                             :description "G5 — derived analyzer output, never re-ingested as authoritative fact"}}}}}}
