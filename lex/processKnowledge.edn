{:lexicon 1
 :id "com.etzhayyim.hotaru.processKnowledge"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["procId" "stage" "sourceLicense" "sourceCite" "maturity" "screened"]
    :properties
    {:procId        {:type "string" :description "→ iii-v-substrate-ontology :iiiv.proc/id"}
     :stage         {:type "string" :enum ["synthesis" "bulk-growth" "wafering" "surface-prep" "epitaxy"]}
     :method        {:type "string" :description "e.g. lec / vgf / vertical-bridgman / wire-saw / cmp / movpe"}
     :sourceLicense {:type "string" :enum ["academic-oa" "patent-expired" "textbook-public" "standard-public" "own-rnd"]
                     :description "G1 INVARIANT — practiceable-open ONLY; vendor-proprietary/patent-active/trade-secret are NOT enum members (rejected by ValueError before a record exists)"}
     :sourceCite    {:type "string" :description "G5 — primary-source citation (DOI / expired-patent no. / textbook / SEMI std)"}
     :maturity      {:type "string" :enum ["open-mature" "open-emerging" "gap"]
                     :description "gap = vendor-IP-dense (full recipe NOT in commons); the :epitaxy stage's binding constraint"}
     :screened      {:type "boolean" :const true
                     :description "G1 — record only exists after the open-IP license screen passes"}
     :sourcing      {:type "string" :enum ["representative" "verified"]}}}}}}
