{:lexicon 1
 :id "com.etzhayyim.hotaru.crystalGrowthDesign"
 :defs
 {:main
  {:type "record"
   :key "tid"
   :record
   {:type "object"
    :required ["crystalId" "material" "method" "inSourcing" "fabricated"]
    :properties
    {:crystalId   {:type "string" :description "→ :iiiv.crystal/id"}
     :material    {:type "string" :description "→ :iiiv.material/id (e.g. inp)"}
     :method      {:type "string" :enum ["lec" "vgf" "vertical-bridgman"]}
     :dopant      {:type "string" :description "e.g. sulfur (n) / iron (semi-insulating) / undoped"}
     :targetWafer {:type "string" :description "→ :iiiv.wafer/id"}
     :inSourcing  {:type "string" :enum ["recycled" "conflict-free-attested"]
                   :description "G4 INVARIANT — conflict-mineral In/Ga sourcing; :unverified is NOT an enum member (refused by precursor_safety review)"}
     :fabricated  {:type "boolean" :const false
                   :description "G2 INVARIANT — DESIGN ONLY through R3. Only false is valid; a grown boule is unrepresentable until the ADR-2605265500 R4+ gate (Council Lv7+)"}
     :sourcing    {:type "string" :enum ["representative" "verified"]}}}}}}
