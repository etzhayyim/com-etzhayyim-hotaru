  "constitutionalGates": {
    "description": "11 immutable gates per ADR-2606051200. G1 (open-IP-only) + G2 (design-only/not-fabricated) + G3 (non-adjudicating on the R4+ gate) are the structural anchors; G4 (conflict-mineral) inherits hikari/himawari §G2.",
    "gates": {
      "G1": "Open-IP only — :source-license ∈ {academic-oa, patent-expired, textbook-public, standard-public, own-rnd}; vendor-proprietary/patent-active/trade-secret unrepresentable (schema + lexicon enum + code)",
      "G2": "Design-only/not-fabricated — :fabricated allowed [false]; III-V fabrication PROHIBITED through R3 (ADR-2605265500 §2)",
      "G3": "Non-adjudicating on the gate — hotaru reports the R4+ gate facts; Council Lv7+ decides; silenHotaruReview never opens fabrication",
      "G4": "Conflict-mineral sourcing — In/Ga consumed requires :in-sourcing clean (recycled/conflict-free-attested); inherits hikari/himawari §G2",
      "G5": "No-server-key — future authorization member/operator-signed; server signature refused (ADR-2605231525)",
      "G6": "Murakumo-only inference (ADR-2605215000)",
      "G7": "Sourcing-honesty — :representative seed; primary-source verification before outward use",
      "G8": "Outward-gated — real growth/fab/live-ingest/publish all Council Lv7+ + operator (Lv7+, not Lv6+, because III-V is constitutionally gated through R3)",
      "G9": "Export-control-honest — ITAR/EAR posture recorded for ADR-2605265500 §2 jurisdictional-risk attestation",
      "G10": "Civilian-only — no fire-control/weapons/military RF-seeker designs (Charter §2(a) force-separation)",
      "G11": "Process-safety — acute-toxic-pyrophoric precursors (PH3) acknowledged via precursor_safety refusal gate before any design clears"
    }
  },
  "nonGoals": {
    "description": "6 explicitly excluded scopes",
    "goals": {
      "N1": "No military/fire-control/weapons-seeker III-V designs (civilian only)",
      "N2": "NOT a III-V fab — design/datafication/sim only; fabrication PROHIBITED through R3",
      "N3": "No vendor-proprietary MOCVD/epitaxy recipe ingest or reverse-engineering",
      "N4": "Not the silicon iwakura/fuigo logic-ASIC track nor himawari solar-Si PV",
      "N5": "No In/Ga sourced without conflict-free/recycled attestation",
      "N6": "Does NOT decide or advocate the ADR-2605265500 R4+ gate (Council Lv7+ only)"
    }
  },
  "roadmap": [
    { "phase": "R0", "date": "2026-06-05", "scope": "This ADR. Ontology + 6 lexicons + 5 cells (all 5 coded state machines) + analyzer (maturity-score + per-material chain-completeness) + :representative seed. Substrate commons READY (4/4 stages open-mature, maturity 1.00); epitaxy GAP; R4+ gate NOT satisfiable from the commons alone → fabrication stays prohibited. 53 tests green. No runtime/sim/live-kotoba.", "gate": "ADR-2606051200 (PROPOSED) + ADR-2605265500 §2 inherited" },
    { "phase": "R1", "date": "post-Council", "scope": "Expand the open commons (more open-publication processes; close :open-emerging → :open-mature); bulk-growth thermal-field simulation (kami-genesis); honest epitaxy-gap map. Still design/sim only.", "gate": "Future ADR + ≥1 compound-semiconductor crystal-growth engineer on Council technical advisory" },
