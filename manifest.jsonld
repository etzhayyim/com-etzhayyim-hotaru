    { "name": "bulk_crystal_design", "module": "hotaru.cells.bulk_crystal_design", "murakumoNode": "naphtali", "phase": "single-crystal InP boule growth design + thermal-field sim (LEC/VGF/VB)", "status": "coded-state-machine", "emitsLexicon": "com.etzhayyim.hotaru.crystalGrowthDesign", "gates": ["G2", "G4", "G8", "N2"] },
